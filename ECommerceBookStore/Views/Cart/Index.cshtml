@model IEnumerable<ECommereceBookStore.Models.CartItem>
@{
    ViewData["Title"] = "My Cart";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2 text-danger"></i>My Cart</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-cart-arrow-down fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Your cart is empty</h4>
            <a asp-controller="Book" asp-action="Index" class="btn btn-danger mt-3">
                <i class="fas fa-book me-2"></i>Browse Books
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Book</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@item.Book.ImageUrl"
                                         style="width:55px;height:70px;object-fit:contain;"
                                         onerror="this.src='https://via.placeholder.com/55x70?text=Book'"
                                         alt="@item.Book.Title" />
                                    <div>
                                        <div class="fw-bold">@item.Book.Title</div>
                                        <small class="text-muted">@item.Book.Author</small>
                                    </div>
                                </div>
                            </td>
                            <td>₹@item.Book.Price</td>
                            <td>@item.Quantity</td>
                            <td class="fw-bold text-danger">₹@(item.Book.Price* item.Quantity)</td>
                            <td>
                                <form asp-controller="Cart" asp-action="Remove" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="fas fa-trash"></i> Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold fs-5">Total:</td>
                        <td class="fw-bold fs-5 text-danger">
                            ₹@Model.Sum(i => i.Book.Price * i.Quantity)
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="text-end mt-3">
            <a asp-controller="Book" asp-action="Index" class="btn btn-outline-secondary me-2">
                <i class="fas fa-arrow-left me-1"></i>Continue Shopping
            </a>
            <form asp-controller="Cart" asp-action="Checkout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="fas fa-check me-2"></i>Place Order
                </button>
            </form>
        </div>
    }
</div>