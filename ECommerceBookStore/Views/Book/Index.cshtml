@model IEnumerable<ECommereceBookStore.Models.Book>
@{
    ViewData["Title"] = "All Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-books me-2"></i>All Books</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Add New Book
        </a>
    }
</div>

<!-- Search & Filter -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-6">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Search by title or author..." />
        </div>
        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                <option value="Fiction" selected="@(ViewBag.Category == "Fiction")">Fiction</option>
                <option value="Fantasy" selected="@(ViewBag.Category == "Fantasy")">Fantasy</option>
                <option value="Classic" selected="@(ViewBag.Category == "Classic")">Classic</option>
                <option value="Finance" selected="@(ViewBag.Category == "Finance")">Finance</option>
                <option value="Self Help" selected="@(ViewBag.Category == "Self Help")">Self Help</option>
                <option value="Business" selected="@(ViewBag.Category == "Business")">Business</option>
                <option value="Thriller" selected="@(ViewBag.Category == "Thriller")">Thriller</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-search me-1"></i>Search
            </button>
        </div>
    </div>
</form>

<!-- Book Cards -->
<div class="row row-cols-1 row-cols-md-4 g-4">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 book-card">
                <img src="@book.ImageUrl" class="card-img-top p-3"
                     style="height:200px;object-fit:contain;"
                     onerror="this.src='https://via.placeholder.com/150x200?text=No+Image'"
                     alt="@book.Title" />
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold">@book.Title</h6>
                    <p class="text-muted small mb-1"><i class="fas fa-user me-1"></i>@book.Author</p>
                    <span class="badge bg-primary mb-2" style="width:fit-content">@book.Category</span>
                    <p class="text-muted small">@(book.Description?.Length > 60 ? book.Description.Substring(0, 60) + "..." : book.Description)</p>
                    <p class="fw-bold text-danger fs-5 mt-auto">₹@book.Price</p>
                    <p class="text-muted small mb-2">
                        <i class="fas fa-box me-1"></i>Stock: @book.Stock
                    </p>
                    <div class="d-flex gap-1 flex-wrap">
                        <a asp-action="Details" asp-route-id="@book.Id"
                           class="btn btn-outline-info btn-sm">
                            <i class="fas fa-eye"></i>
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@book.Id"
                               class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-controller="Book"
                               asp-action="Delete"
                               asp-route-id="@book.Id"
                               class="btn btn-danger btn-sm">Delete
                                <i class="fas fa-trash"></i>
                            </a>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-fill">
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-danger btn-sm w-100">
                                    <i class="fas fa-cart-plus me-1"></i>Add to Cart
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login"
                               class="btn btn-danger btn-sm flex-fill">
                                <i class="fas fa-cart-plus me-1"></i>Add to Cart
                            </a>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@book.Id"
                               class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>

                            <a asp-controller="Book"
                               asp-action="Delete"
                               asp-route-id="@book.Id"
                               class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .book-card {
        transition: transform 0.2s;
    }

        .book-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.12) !important;
        }
</style>