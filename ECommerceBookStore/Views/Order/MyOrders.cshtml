@model IEnumerable<ECommereceBookStore.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-box me-2 text-primary"></i>My Orders</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No orders yet</h4>
            <a asp-controller="Book" asp-action="Index" class="btn btn-danger mt-3">
                <i class="fas fa-book me-2"></i>Browse Books
            </a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><strong>Order #@order.Id</strong> — @order.OrderDate.ToString("dd MMM yyyy")</span>
                    <span class="badge @(order.Status == "Pending" ? "bg-warning text-dark" :
                                                                   order.Status == "Delivered" ? "bg-success" : "bg-info")">
                @order.Status
            </span>
        </div>
        <div class="card-body">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Qty</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td>@item.Book?.Title</td>
                                    <td>@item.Quantity</td>
                                    <td>₹@item.Price</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <strong>Total: ₹@order.TotalAmount</strong>
                    <a asp-controller="Order" asp-action="Details"
                       asp-route-id="@order.Id"
                       class="btn btn-outline-primary btn-sm">View Details</a>
                </div>
            </div>
        }
    }
</div>