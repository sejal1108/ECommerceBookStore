@model ECommereceBookStore.Models.Order
@{
    ViewData["Title"] = "Receipt - Order #" + Model.Id;
    Layout = null;

    string statusColor = "#f59e0b";
    if (Model.Status == "Delivered") { statusColor = "#10b981"; }
    if (Model.Status == "Shipped") { statusColor = "#3b82f6"; }
    if (Model.Status == "Cancelled") { statusColor = "#ef4444"; }
    if (Model.Status == "Processing") { statusColor = "#8b5cf6"; }

    decimal subtotal = Model.OrderItems.Sum(i => i.Price * i.Quantity);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receipt — Order #@Model.Id | BookStore</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f3f4f6;
            color: #111827;
            font-size: 14px;
            line-height: 1.5;
        }

        /* ── Top action bar — hidden on print ── */
        .action-bar {
            background: #1a1a2e;
            color: #fff;
            padding: 12px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .action-bar .left {
                display: flex;
                flex-direction: column;
            }

                .action-bar .left strong {
                    font-size: 15px;
                }

                .action-bar .left span {
                    font-size: 12px;
                    opacity: 0.6;
                    margin-top: 2px;
                }

        .btn-group {
            display: flex;
            gap: 10px;
        }

        .btn {
            padding: 9px 22px;
            border: none;
            border-radius: 7px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: opacity .15s;
        }

            .btn:hover {
                opacity: .85;
            }

        .btn-pdf {
            background: #e94560;
            color: #fff;
        }

        .btn-back {
            background: rgba(255,255,255,.12);
            color: #fff;
            border: 1px solid rgba(255,255,255,.25);
        }

        /* ── Receipt card ── */
        .page {
            max-width: 760px;
            margin: 32px auto 60px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 6px 32px rgba(0,0,0,.10);
            overflow: hidden;
        }

        /* Header */
        .rh {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
            color: #fff;
            padding: 32px 40px 28px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .rh-brand .name {
            font-size: 24px;
            font-weight: 800;
            color: #e94560;
            letter-spacing: .4px;
        }

        .rh-brand .tagline {
            font-size: 11px;
            opacity: .55;
            margin-top: 3px;
        }

        .rh-meta {
            text-align: right;
        }

            .rh-meta h2 {
                font-size: 20px;
                font-weight: 700;
                letter-spacing: 1.5px;
                text-transform: uppercase;
            }

            .rh-meta p {
                font-size: 12px;
                opacity: .6;
                margin-top: 4px;
            }

        /* Info grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-bottom: 1px solid #e5e7eb;
        }

        .ig-cell {
            padding: 16px 22px;
            border-right: 1px solid #e5e7eb;
        }

            .ig-cell:last-child {
                border-right: none;
            }

            .ig-cell .lbl {
                font-size: 10px;
                text-transform: uppercase;
                letter-spacing: .6px;
                color: #9ca3af;
                margin-bottom: 5px;
            }

            .ig-cell .val {
                font-size: 13px;
                font-weight: 700;
                color: #111827;
            }

        .status-pill {
            display: inline-block;
            padding: 3px 11px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
        }

        /* Addresses */
        .addr-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-bottom: 1px solid #e5e7eb;
        }

        .addr-box {
            padding: 18px 22px;
        }

            .addr-box:first-child {
                border-right: 1px solid #e5e7eb;
            }

            .addr-box .lbl {
                font-size: 10px;
                text-transform: uppercase;
                letter-spacing: .6px;
                color: #9ca3af;
                margin-bottom: 8px;
            }

            .addr-box p {
                font-size: 13px;
                color: #374151;
                line-height: 1.65;
            }

            .addr-box strong {
                color: #111827;
            }

        /* Items table */
        .items {
            padding: 0 22px;
        }

        .items-hdr {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #9ca3af;
            padding: 16px 0 8px;
            border-bottom: 2px solid #e5e7eb;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

            table thead th {
                padding: 9px 6px;
                font-size: 11px;
                font-weight: 700;
                color: #6b7280;
                text-align: left;
                background: #f9fafb;
                border-bottom: 1px solid #e5e7eb;
            }

                table thead th.r {
                    text-align: right;
                }

            table tbody td {
                padding: 11px 6px;
                border-bottom: 1px solid #f3f4f6;
                font-size: 13px;
                color: #374151;
                vertical-align: middle;
            }

                table tbody td.r {
                    text-align: right;
                    font-weight: 600;
                    color: #111;
                }

        .book-title {
            font-weight: 700;
            color: #111827;
        }

        .book-sub {
            font-size: 11px;
            color: #9ca3af;
            margin-top: 2px;
        }

        /* Totals */
        .totals {
            padding: 14px 22px 22px;
        }

        .totals-inner {
            margin-left: auto;
            width: 290px;
        }

        .t-row {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            font-size: 13px;
            color: #6b7280;
        }

            .t-row span:last-child {
                font-weight: 600;
                color: #374151;
            }

            .t-row.free span:last-child {
                color: #10b981;
                font-weight: 700;
            }

        .t-divider {
            border: none;
            border-top: 2px solid #e5e7eb;
            margin: 8px 0;
        }

        .t-total {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
        }

            .t-total span:first-child {
                font-size: 15px;
                font-weight: 800;
                color: #111;
            }

            .t-total span:last-child {
                font-size: 17px;
                font-weight: 800;
                color: #e94560;
            }

        /* Footer */
        .rf {
            background: #f9fafb;
            border-top: 1px dashed #d1d5db;
            padding: 20px 40px;
            text-align: center;
        }

            .rf .ty {
                font-size: 15px;
                font-weight: 800;
                color: #1a1a2e;
                margin-bottom: 5px;
            }

            .rf p {
                font-size: 11px;
                color: #9ca3af;
                line-height: 1.8;
            }

        /* Watermark for delivered orders */
        .watermark {
            text-align: center;
            padding: 10px 0 0;
            font-size: 11px;
            color: #10b981;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* ── Print ── */
        @@media print {
            body {
                background: #fff;
            }

            .action-bar {
                display: none !important;
            }

            .page {
                margin: 0;
                box-shadow: none;
                border-radius: 0;
            }

            @@page {
                margin: 8mm;
                size: A4;
            }
        }
    </style>
</head>
<body>

    <!-- Action Bar -->
    <div class="action-bar">
        <div class="left">
            <strong>&#129106; Payment Receipt &mdash; Order #@Model.Id</strong>
            <span>BookStore &bull; @Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</span>
        </div>
        <div class="btn-group">
            <a href="/Order/MyOrders" class="btn btn-back">&#8592; My Orders</a>
            <button onclick="downloadPDF()" class="btn btn-pdf" id="dlBtn">
                &#11015; Download PDF
            </button>
        </div>
    </div>

    <!-- Receipt -->
    <div class="page" id="receipt">

        <!-- Header -->
        <div class="rh">
            <div class="rh-brand">
                <div class="name">&#128218; BookStore</div>
                <div class="tagline">Your favourite online bookstore</div>
            </div>
            <div class="rh-meta">
                <h2>Receipt</h2>
                <p>Order #@Model.Id</p>
                <p>@Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</p>
            </div>
        </div>

        <!-- Info Grid -->
        <div class="info-grid">
            <div class="ig-cell">
                <div class="lbl">Order ID</div>
                <div class="val">#@Model.Id</div>
            </div>
            <div class="ig-cell">
                <div class="lbl">Order Date</div>
                <div class="val">@Model.OrderDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="ig-cell">
                <div class="lbl">Payment Mode</div>
                <div class="val">COD / Online</div>
            </div>
            <div class="ig-cell">
                <div class="lbl">Status</div>
                <div class="val">
                    <span class="status-pill" style="background:@statusColor;">@Model.Status</span>
                </div>
            </div>
        </div>

        <!-- Customer + Shipping -->
        <div class="addr-row">
            <div class="addr-box">
                <div class="lbl">Customer Details</div>
                <p><strong>@Model.User?.FullName</strong></p>
                <p>@Model.User?.Email</p>
                @if (!string.IsNullOrEmpty(Model.User?.PhoneNumber))
                {
                    <p>@Model.User.PhoneNumber</p>
                }
            </div>
            <div class="addr-box">
                <div class="lbl">Shipping Address</div>
                <p>@(string.IsNullOrEmpty(Model.ShippingAddress) ? "Not provided" : Model.ShippingAddress)</p>
            </div>
        </div>

        <!-- Items Table -->
        <div class="items">
            <div class="items-hdr">Order Items</div>
            <table>
                <thead>
                    <tr>
                        <th style="width:40%;">Book Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th class="r">Unit Price</th>
                        <th class="r">Qty</th>
                        <th class="r">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>
                                <div class="book-title">@item.Book?.Title</div>
                                <div class="book-sub">ISBN / Digital Copy</div>
                            </td>
                            <td style="color:#6b7280;">@item.Book?.Author</td>
                            <td>
                                <span style="background:#eff6ff;color:#1d4ed8;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:600;">
                                    @item.Book?.Category
                                </span>
                            </td>
                            <td class="r">&#8377;@item.Price.ToString("N2")</td>
                            <td class="r">@item.Quantity</td>
                            <td class="r">&#8377;@((item.Price * item.Quantity).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="totals">
            <div class="totals-inner">
                <div class="t-row">
                    <span>Subtotal (@Model.OrderItems.Count item(s))</span>
                    <span>&#8377;@subtotal.ToString("N2")</span>
                </div>
                <div class="t-row free">
                    <span>Delivery Charges</span>
                    <span>FREE</span>
                </div>
                <div class="t-row">
                    <span>GST / Tax</span>
                    <span>Included</span>
                </div>
                <div class="t-row">
                    <span>Discount</span>
                    <span>&#8377;0.00</span>
                </div>
                <hr class="t-divider" />
                <div class="t-total">
                    <span>Total Paid</span>
                    <span>&#8377;@Model.TotalAmount.ToString("N2")</span>
                </div>
            </div>
        </div>

        @if (Model.Status == "Delivered")
        {
            <div class="watermark">&#10003; Payment Received &amp; Delivered</div>
        }

        <hr style="border:none;border-top:1px dashed #d1d5db;margin:0 24px 0;" />

        <!-- Footer -->
        <div class="rf">
            <div class="ty">Thank you for shopping with BookStore! &#128218;</div>
            <p>
                This is a system-generated receipt and does not require a physical signature.<br />
                For queries: <strong>support@bookstore.com</strong> &bull; Helpline: 1800-XXX-XXXX
            </p>
            <p style="margin-top:6px;">
                &copy; @DateTime.Now.Year BookStore &mdash; All rights reserved &bull;
                Generated on @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")
            </p>
        </div>

    </div>

    <!-- html2pdf CDN — no NuGet package needed -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function downloadPDF() {
            var btn = document.getElementById('dlBtn');
            btn.textContent = '⏳ Generating...';
            btn.disabled = true;

            var opt = {
                margin:      [5, 5, 5, 5],
                filename: 'BookStore_Receipt_Order_@(Model.Id).pdf',
                image:       { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0 },
                jsPDF:       { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf()
                .set(opt)
                .from(document.getElementById('receipt'))
                .save()
                .then(function () {
                    btn.innerHTML = '✅ Downloaded!';
                    setTimeout(function () {
                        btn.innerHTML = '⬇ Download PDF';
                        btn.disabled = false;
                    }, 3000);
                });
        }
    </script>

</body>
</html>