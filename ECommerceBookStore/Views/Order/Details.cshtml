@model ECommereceBookStore.Models.Order
@{
    ViewData["Title"] = "Order #" + Model.Id;

    string badgeClass = "secondary";
    if (Model.Status == "Pending") { badgeClass = "warning"; }
    if (Model.Status == "Processing") { badgeClass = "info"; }
    if (Model.Status == "Shipped") { badgeClass = "primary"; }
    if (Model.Status == "Delivered") { badgeClass = "success"; }
    if (Model.Status == "Cancelled") { badgeClass = "danger"; }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-receipt me-2 text-info"></i>Order #@Model.Id
        <span class="badge bg-@badgeClass ms-2">@Model.Status</span>
    </h2>
    <div class="d-flex gap-2">
        @* ✅ Download Receipt Button *@
        <a asp-action="DownloadReceipt" asp-route-id="@Model.Id"
           class="btn btn-danger fw-bold" target="_blank">
            <i class="fas fa-file-pdf me-2"></i>Download Receipt
        </a>
        <a asp-action="MyOrders" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>My Orders
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Status Progress -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-4">
        @{
            var steps = new[] { "Pending", "Processing", "Shipped", "Delivered" };
            var curIdx = Array.IndexOf(steps, Model.Status);
            var icons = new[] { "clock", "cog", "truck", "check-circle" };
        }
        <div class="d-flex align-items-center justify-content-between">
            @for (int i = 0; i < steps.Length; i++)
            {
                bool active = (i <= curIdx) && Model.Status != "Cancelled";
                string bg = active ? "#0d6efd" : "#e9ecef";
                string col = active ? "#fff" : "#adb5bd";
                string txt = active ? "text-primary fw-bold" : "text-muted";

                <div class="text-center" style="flex:1;">
                    <div class="rounded-circle mx-auto mb-1 d-flex align-items-center justify-content-center"
                         style="width:38px;height:38px;background:@bg;color:@col;">
                        <i class="fas fa-@(icons[i])" style="font-size:14px;"></i>
                    </div>
                    <small class="@txt">@steps[i]</small>
                </div>

                @if (i < steps.Length - 1)
                {
                    bool lineActive = (i < curIdx) && Model.Status != "Cancelled";
                    <div style="flex:1;height:3px;background:@(lineActive ? "#0d6efd" : "#e9ecef");margin-bottom:20px;border-radius:2px;"></div>
                }
            }
        </div>
        @if (Model.Status == "Cancelled")
        {
            <div class="text-center mt-3">
                <span class="badge bg-danger fs-6 px-4">Order Cancelled</span>
            </div>
        }
    </div>
</div>

<div class="row g-4">

    <!-- Summary Card -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom py-3">
                <i class="fas fa-info-circle me-2 text-primary"></i>Order Summary
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted ps-3">Order ID</td>
                        <td class="fw-bold">#@Model.Id</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-3">Date</td>
                        <td>@Model.OrderDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-3">Status</td>
                        <td><span class="badge bg-@badgeClass">@Model.Status</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-3">Shipping</td>
                        <td style="font-size:12px;">@(Model.ShippingAddress ?? "Not provided")</td>
                    </tr>
                    <tr class="border-top">
                        <td class="text-muted ps-3 fw-bold">Total</td>
                        <td class="fw-bold text-success fs-5">&#8377;@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                </table>
            </div>
            <div class="card-footer bg-white border-top p-3">
                <a asp-action="DownloadReceipt" asp-route-id="@Model.Id"
                   class="btn btn-danger w-100 fw-bold" target="_blank">
                    <i class="fas fa-download me-2"></i>Download PDF Receipt
                </a>
            </div>
        </div>
    </div>

    <!-- Items Card -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom py-3">
                <i class="fas fa-shopping-cart me-2 text-info"></i>
                Items in this Order (@Model.OrderItems.Count)
            </div>
            <div class="card-body p-0">
                @foreach (var item in Model.OrderItems)
                {
                    <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                        <img src="@item.Book?.ImageUrl"
                             alt="@item.Book?.Title"
                             style="width:55px;height:70px;object-fit:contain;border-radius:4px;"
                             onerror="this.src='https://via.placeholder.com/55x70?text=Book'" />
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-bold">@item.Book?.Title</h6>
                            <small class="text-muted">by @item.Book?.Author</small><br />
                            <span class="badge bg-primary mt-1" style="font-size:10px;">@item.Book?.Category</span>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small">&#8377;@item.Price.ToString("N2") &times; @item.Quantity</div>
                            <div class="fw-bold text-success fs-6">&#8377;@item.Subtotal.ToString("N2")</div>
                        </div>
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center p-3 bg-light">
                    <span class="fw-bold">Order Total</span>
                    <span class="fw-bold text-success fs-5">&#8377;@Model.TotalAmount.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>

</div>