@{
    ViewData["Title"] = "Checkout";
    var cartItems = ViewBag.CartItems as List<ECommereceBookStore.Models.CartItem>;
    decimal total = ViewBag.Total;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2>Checkout</h2>

        <form asp-controller="Order" asp-action="PlaceOrder" method="post">
            @Html.AntiForgeryToken()

            <!-- ✅ VERY IMPORTANT -->
            <div class="mb-3">
                <label class="form-label">Shipping Address</label>

                <textarea name="shippingAddress"
                          class="form-control"
                          rows="4"
                          required>
        </textarea>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Place Order ₹@total
            </button>
        </form>

        <hr />

        <h4>Order Summary</h4>

        @foreach (var item in cartItems!)
        {
            <div>
                @item.Book?.Title -
                Qty: @item.Quantity -
                ₹@(item.Book!.Price * item.Quantity)
            </div>
        }

        <h5>Total: ₹@total</h5>
    </div>
</div>