@model ECommereceBookStore.Models.Order
@{
    ViewData["Title"] = "Order #" + Model.Id + " Details";

    string badgeClass = "secondary";
    if (Model.Status == "Pending") { badgeClass = "warning"; }
    if (Model.Status == "Processing") { badgeClass = "info"; }
    if (Model.Status == "Shipped") { badgeClass = "primary"; }
    if (Model.Status == "Delivered") { badgeClass = "success"; }
    if (Model.Status == "Cancelled") { badgeClass = "danger"; }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-receipt me-2 text-info"></i>Order #@Model.Id
        <span class="badge bg-@badgeClass ms-2">@Model.Status</span>
    </h2>
    <a asp-action="Orders" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back to Orders
    </a>
</div>

<div class="row g-4">

    <!-- Order Info -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="fas fa-info-circle me-2 text-primary"></i>Order Information
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted fw-semibold">Order ID</td>
                        <td><strong>#@Model.Id</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Date</td>
                        <td>@Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Status</td>
                        <td><span class="badge bg-@badgeClass">@Model.Status</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Total</td>
                        <td><strong class="text-success fs-5">&#8377;@Model.TotalAmount.ToString("N2")</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Address</td>
                        <td>@(Model.ShippingAddress ?? "Not provided")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Customer Info -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="fas fa-user me-2 text-success"></i>Customer
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary rounded-circle text-white d-flex align-items-center justify-content-center me-3"
                         style="width:48px;height:48px;font-size:1.2rem;">
                        @(Model.User?.FullName?.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">@Model.User?.FullName</h6>
                        <small class="text-muted">@Model.User?.Email</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Update Status -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="fas fa-edit me-2 text-warning"></i>Update Status
            </div>
            <div class="card-body">
                <form asp-controller="Admin" asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <label class="form-label text-muted">Change order status:</label>

                    <select name="newStatus" class="form-select mb-3">
                        @if (Model.Status == "Pending")
                        {
                            <option value="Pending" selected>Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                        else if (Model.Status == "Processing")
                        {
                            <option value="Pending">Pending</option>
                            <option value="Processing" selected>Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                        else if (Model.Status == "Shipped")
                        {
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped" selected>Shipped</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                        else if (Model.Status == "Delivered")
                        {
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Delivered" selected>Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                        else
                        {
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled" selected>Cancelled</option>
                        }
                    </select>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">
                        <i class="fas fa-save me-1"></i>Update Status
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Order Items -->
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white fw-bold border-bottom">
        <i class="fas fa-shopping-cart me-2 text-info"></i>Order Items (@Model.OrderItems.Count)
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Book</th>
                    <th>Author</th>
                    <th>Unit Price</th>
                    <th>Qty</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td class="ps-3">
                            <span class="fw-semibold">@item.Book?.Title</span>
                        </td>
                        <td class="text-muted">@item.Book?.Author</td>
                        <td>&#8377;@item.Price.ToString("N2")</td>
                        <td>x@item.Quantity</td>

                        <!-- ✅ FIXED LINE -->
                        <td class="fw-bold text-success">
                            &#8377;@((item.Quantity * item.Price).ToString("N2"))
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>