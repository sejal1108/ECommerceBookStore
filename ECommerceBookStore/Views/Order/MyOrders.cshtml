@model IEnumerable<ECommereceBookStore.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-box me-2 text-primary"></i>My Orders</h2>
    <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="fas fa-book me-1"></i>Continue Shopping
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-shopping-bag fa-4x text-muted mb-3 d-block"></i>
        <h4 class="text-muted">No orders yet</h4>
        <p class="text-muted">You have not placed any orders. Start shopping!</p>
        <a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg mt-2">
            <i class="fas fa-book me-2"></i>Browse Books
        </a>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        string badgeClass = "secondary";
        if (order.Status == "Pending") { badgeClass = "warning"; }
        if (order.Status == "Processing") { badgeClass = "info"; }
        if (order.Status == "Shipped") { badgeClass = "primary"; }
        if (order.Status == "Delivered") { badgeClass = "success"; }
        if (order.Status == "Cancelled") { badgeClass = "danger"; }

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <strong class="fs-6">Order #@order.Id</strong>
                        <span class="text-muted ms-3 small">
                            <i class="fas fa-calendar me-1"></i>
                            @order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                        </span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-@badgeClass fs-6">@order.Status</span>

                        @* View Details *@
                        <a asp-action="Details" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-info">
                            <i class="fas fa-eye me-1"></i>Details
                        </a>

                        @* ✅ Download Receipt *@
                        <a asp-action="DownloadReceipt" asp-route-id="@order.Id"
                           class="btn btn-sm btn-danger" target="_blank">
                            <i class="fas fa-download me-1"></i>Receipt
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var item in order.OrderItems.Take(4))
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@item.Book?.ImageUrl"
                                         alt="@item.Book?.Title"
                                         style="width:42px;height:52px;object-fit:contain;border-radius:4px;"
                                         onerror="this.src='https://via.placeholder.com/42x52?text=Book'" />
                                    <div>
                                        <div class="fw-semibold small">@item.Book?.Title</div>
                                        <small class="text-muted">
                                            Qty: @item.Quantity &mdash; &#8377;@item.Price.ToString("N2")
                                        </small>
                                    </div>
                                </div>
                            }
                            @if (order.OrderItems.Count > 4)
                            {
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-secondary">
                                        +@(order.OrderItems.Count - 4) more
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <p class="text-muted small mb-1">@order.OrderItems.Count item(s)</p>
                        <h5 class="fw-bold text-success mb-0">&#8377;@order.TotalAmount.ToString("N2")</h5>
                    </div>
                </div>
            </div>
        </div>
    }
}