@model IEnumerable<ECommereceBookStore.Models.Book>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="p-5 mb-5 rounded-4 text-white text-center"
     style="background: linear-gradient(135deg, #1a1a2e, #e94560);">
    <h1 class="display-4 fw-bold">
        <i class="fas fa-book-open me-3"></i>Welcome to BookStore
    </h1>
    <p class="lead mb-4">Discover your next favourite book from our collection</p>
    <a asp-controller="Book" asp-action="Index" class="btn btn-light btn-lg px-5">
        <i class="fas fa-search me-2"></i>Browse All Books
    </a>
</div>

<!-- Category Pills -->
<div class="d-flex flex-wrap gap-2 mb-4 justify-content-center">
    <a asp-controller="Book" asp-action="Index" asp-route-category="Fiction"
       class="btn btn-outline-primary rounded-pill px-4">Fiction</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Fantasy"
       class="btn btn-outline-success rounded-pill px-4">Fantasy</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Classic"
       class="btn btn-outline-warning rounded-pill px-4">Classic</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Finance"
       class="btn btn-outline-info rounded-pill px-4">Finance</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Self Help"
       class="btn btn-outline-danger rounded-pill px-4">Self Help</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Business"
       class="btn btn-outline-secondary rounded-pill px-4">Business</a>
    <a asp-controller="Book" asp-action="Index" asp-route-category="Thriller"
       class="btn btn-outline-dark rounded-pill px-4">Thriller</a>
</div>

<!-- Featured Books -->
<h3 class="fw-bold mb-4"><i class="fas fa-star text-warning me-2"></i>Featured Books</h3>

<div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 book-card">
                <img src="@book.ImageUrl" class="card-img-top p-3"
                     style="height:220px;object-fit:contain;"
                     onerror="this.src='https://via.placeholder.com/150x220?text=No+Image'"
                     alt="@book.Title" />
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold">@book.Title</h6>
                    <p class="text-muted small mb-1">@book.Author</p>
                    <span class="badge bg-primary mb-2" style="width:fit-content">@book.Category</span>
                    <p class="fw-bold text-danger fs-5 mt-auto">₹@book.Price</p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Book" asp-action="Details"
                           asp-route-id="@book.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="fas fa-eye me-1"></i>Details
                        </a>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-fill">
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-danger btn-sm w-100">
                                    <i class="fas fa-cart-plus me-1"></i>Add
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login"
                               class="btn btn-danger btn-sm flex-fill">
                                <i class="fas fa-cart-plus me-1"></i>Add
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Stats Section -->
<div class="row text-center g-4 mb-5">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <i class="fas fa-book fa-3x text-primary mb-3"></i>
            <h4 class="fw-bold">500+</h4>
            <p class="text-muted">Books Available</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <i class="fas fa-users fa-3x text-success mb-3"></i>
            <h4 class="fw-bold">10,000+</h4>
            <p class="text-muted">Happy Readers</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <i class="fas fa-shipping-fast fa-3x text-warning mb-3"></i>
            <h4 class="fw-bold">Free</h4>
            <p class="text-muted">Delivery Available</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4">
            <i class="fas fa-headset fa-3x text-danger mb-3"></i>
            <h4 class="fw-bold">24/7</h4>
            <p class="text-muted">Customer Support</p>
        </div>
    </div>
</div>

<style>
    .book-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .book-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }
</style>