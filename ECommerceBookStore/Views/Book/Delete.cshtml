@model ECommereceBookStore.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="container mt-4">
    <h2 class="text-danger">⚠️ Delete Book</h2>
    <p class="text-muted">Are you sure you want to delete this book? This cannot be undone.</p>

    <div class="card shadow-sm" style="max-width: 450px;">
        <div class="card-body">
            <p><strong>Title:</strong> @Model.Title</p>
            <p><strong>Author:</strong> @Model.Author</p>
            <p><strong>Genre:</strong> @Model.Description</p>
            <p><strong>Price:</strong> ₹@Model.Price</p>
            <p><strong>Stock:</strong> @Model.Stock</p>
        </div>
    </div>

    <div class="mt-3">
        <form asp-controller="Book" asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">✅ Yes, Delete</button>
            <a asp-controller="Book" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>